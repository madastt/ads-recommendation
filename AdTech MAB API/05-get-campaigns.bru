meta {
  name: Get Campaigns
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/campaigns
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

tests {
  test("status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  test("response is an array", function() {
    expect(res.getBody()).to.be.an("array");
  });
}
