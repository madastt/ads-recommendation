meta {
  name: Update Campaign
  type: http
  seq: 6
}

put {
  url: {{baseUrl}}/campaigns/{{campaignId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "name": "Kampania testowa Bruno (zaktualizowana)",
    "start_date": "2026-07-01T00:00:00Z",
    "end_date": "2026-12-31T00:00:00Z"
  }
}

tests {
  test("status is 204", function() {
    expect(res.getStatus()).to.equal(204);
  });
}
