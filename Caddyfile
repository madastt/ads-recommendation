localhost {
    # 1. Żądania do API, Swaggera i plików wędrują do serwera Go (backend)
    handle /api/* {
        reverse_proxy api:8080
    }
    handle /swagger/* {
        reverse_proxy api:8080
    }
    handle /uploads/* {
        reverse_proxy api:8080
    }

    # 2. Wszystko inne (cała reszta ruchu) wędruje do Reacta (frontend)
    handle {
        reverse_proxy frontend:5173
    }
}