{
    "swagger": "2.0",
    "info": {
        "description": "REST API serwera dla systemu optymalizacji reklam w oparciu o algorytmy Multi-Armed Bandit.",
        "title": "AdTech MAB Optimization API",
        "termsOfService": "http://swagger.io/terms/",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/api/v1",
    "paths": {
        "/ads": {
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Wgrywa plik graficzny i przypisuje go do kampanii. Zwraca URL obrazka. Wymaga autoryzacji JWT.",
                "consumes": [
                    "multipart/form-data"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "ads"
                ],
                "summary": "Dodaj reklamę z banerem",
                "parameters": [
                    {
                        "type": "string",
                        "description": "UUID przypisanej kampanii",
                        "name": "campaign_id",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Cechy kontekstowe JSON (np. celowana grupa wiekowa, urządzenia)",
                        "name": "context_features",
                        "in": "formData",
                        "required": true
                    },
                    {
                        "type": "file",
                        "description": "Plik graficzny banera (.png, .jpg)",
                        "name": "image",
                        "in": "formData",
                        "required": true
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Utworzona reklama ze ścieżką do pliku",
                        "schema": {
                            "$ref": "#/definitions/models.Ad"
                        }
                    },
                    "400": {
                        "description": "Brakujące pola lub plik jest zbyt duży",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Błąd zapisu na dysku lub w bazie",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/ads/{id}": {
            "delete": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Usuwa powiązane zdarzenia, rekord z bazy oraz fizyczny plik z dysku. Wymaga autoryzacji JWT.",
                "tags": [
                    "ads"
                ],
                "summary": "Usuń reklamę i jej statystyki",
                "parameters": [
                    {
                        "type": "string",
                        "description": "UUID Reklamy",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Pomyślnie usunięto"
                    },
                    "400": {
                        "description": "Brakujące ID reklamy",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "404": {
                        "description": "Reklama nie istnieje",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Błąd serwera",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/auth/login": {
            "post": {
                "description": "Weryfikuje poświadczenia i zwraca token JWT ważny 24 godziny.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "Logowanie do systemu",
                "parameters": [
                    {
                        "description": "Dane logowania (admin / admin123)",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/handlers.LoginRequest"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Zwraca token JWT",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    },
                    "400": {
                        "description": "Niepoprawny format JSON",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "401": {
                        "description": "Nieprawidłowe dane logowania",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/campaigns": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Zwraca wszystkie kampanie reklamowe zarejestrowane w bazie danych PostgreSQL.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "campaigns"
                ],
                "summary": "Pobierz listę kampanii",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/models.Campaign"
                            }
                        }
                    },
                    "500": {
                        "description": "Błąd wewnętrzny serwera",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            },
            "post": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Dodaje nową kampanię reklamową. Wymaga ważnego tokena JWT.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "campaigns"
                ],
                "summary": "Utwórz nową kampanię",
                "parameters": [
                    {
                        "description": "Dane kampanii (name, start_date, end_date)",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.Campaign"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Utworzona kampania",
                        "schema": {
                            "$ref": "#/definitions/models.Campaign"
                        }
                    },
                    "400": {
                        "description": "Niepoprawny format JSON",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Błąd zapisu do bazy",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/campaigns/{id}": {
            "put": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Modyfikuje parametry istniejącej kampanii (nazwę oraz ramy czasowe). Wymaga ważnego tokena JWT.",
                "consumes": [
                    "application/json"
                ],
                "tags": [
                    "campaigns"
                ],
                "summary": "Aktualizuj istniejącą kampanię",
                "parameters": [
                    {
                        "type": "string",
                        "description": "UUID Kampanii",
                        "name": "id",
                        "in": "path",
                        "required": true
                    },
                    {
                        "description": "Nowe dane kampanii (wymagane: name, start_date, end_date)",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.Campaign"
                        }
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Pomyślnie zaktualizowano (Brak zawartości)"
                    },
                    "400": {
                        "description": "Brakujące ID kampanii lub niepoprawny format JSON",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "404": {
                        "description": "Nie znaleziono kampanii do aktualizacji",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Błąd wewnętrzny serwera",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            },
            "delete": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Zmienia status kampanii na 'archived', chroniąc historię statystyk reklam.",
                "tags": [
                    "campaigns"
                ],
                "summary": "Zarchiwizuj kampanię (Soft Delete)",
                "parameters": [
                    {
                        "type": "string",
                        "description": "UUID Kampanii",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "204": {
                        "description": "Pomyślnie zarchiwizowano (Brak zawartości)"
                    },
                    "400": {
                        "description": "Brakujące ID kampanii",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "404": {
                        "description": "Nie znaleziono kampanii lub już zarchiwizowana",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Błąd wewnętrzny serwera",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/campaigns/{id}/ads": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Zwraca wszystkie banery przypisane do konkretnego UUID kampanii. Wymaga autoryzacji JWT.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "ads"
                ],
                "summary": "Pobierz reklamy dla kampanii",
                "parameters": [
                    {
                        "type": "string",
                        "description": "UUID Kampanii",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Lista reklam",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/models.Ad"
                            }
                        }
                    },
                    "400": {
                        "description": "Brakujące ID kampanii",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Błąd pobierania danych z bazy",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/campaigns/{id}/stats": {
            "get": {
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "description": "Agreguje wyświetlenia i kliknięcia dla wszystkich reklam w kampanii i wylicza CTR. Wymaga autoryzacji JWT.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "campaigns"
                ],
                "summary": "Pobierz statystyki kampanii",
                "parameters": [
                    {
                        "type": "string",
                        "description": "UUID Kampanii",
                        "name": "id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Statystyki reklam",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/models.AdStats"
                            }
                        }
                    },
                    "400": {
                        "description": "Brakujące ID kampanii",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Błąd pobierania danych z bazy",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/events": {
            "post": {
                "description": "Zapisuje wyświetlenie (impression) lub kliknięcie (click). Endpoint publiczny - zbiera dane dla algorytmu LinUCB.",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "events"
                ],
                "summary": "Zarejestruj zdarzenie (Log)",
                "parameters": [
                    {
                        "description": "Dane zdarzenia (ad_id, event_type: 'impression'/'click', user_context)",
                        "name": "request",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/models.Event"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Zapisane zdarzenie",
                        "schema": {
                            "$ref": "#/definitions/models.Event"
                        }
                    },
                    "400": {
                        "description": "Brakujące dane lub niepoprawny event_type",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Błąd zapisu do bazy",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/public/campaigns/active": {
            "get": {
                "description": "Zwraca najnowszą kampanię ze statusem \"active\". Używane przez sklep, żeby automatycznie\nwyświetlać reklamy z bieżącej kampanii bez znajomości jej UUID.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "campaigns"
                ],
                "summary": "Pobierz aktualnie aktywną kampanię (publiczne)",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/models.Campaign"
                        }
                    },
                    "404": {
                        "description": "Brak aktywnej kampanii",
                        "schema": {
                            "type": "string"
                        }
                    },
                    "500": {
                        "description": "Błąd wewnętrzny serwera",
                        "schema": {
                            "type": "string"
                        }
                    }
                }
            }
        },
        "/ws": {
            "get": {
                "description": "Endpoint służący do nasłuchiwania w czasie rzeczywistym na nowe zdarzenia (logi reklam).",
                "tags": [
                    "websockets"
                ],
                "summary": "Nawiąż połączenie WebSocket",
                "responses": {}
            }
        }
    },
    "definitions": {
        "handlers.LoginRequest": {
            "type": "object",
            "properties": {
                "password": {
                    "type": "string"
                },
                "username": {
                    "type": "string"
                }
            }
        },
        "models.Ad": {
            "type": "object",
            "properties": {
                "campaign_id": {
                    "type": "string"
                },
                "context_features": {
                    "type": "string"
                },
                "created_at": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "image_url": {
                    "type": "string"
                }
            }
        },
        "models.AdStats": {
            "type": "object",
            "properties": {
                "ad_id": {
                    "type": "string"
                },
                "clicks": {
                    "type": "integer"
                },
                "ctr": {
                    "type": "number"
                },
                "impressions": {
                    "type": "integer"
                }
            }
        },
        "models.Campaign": {
            "type": "object",
            "properties": {
                "created_at": {
                    "type": "string"
                },
                "end_date": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "name": {
                    "type": "string"
                },
                "start_date": {
                    "type": "string"
                },
                "status": {
                    "description": "active, paused, completed",
                    "type": "string"
                }
            }
        },
        "models.Event": {
            "type": "object",
            "properties": {
                "ad_id": {
                    "type": "string"
                },
                "created_at": {
                    "type": "string"
                },
                "event_type": {
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "user_context": {
                    "type": "string"
                }
            }
        }
    },
    "securityDefinitions": {
        "BearerAuth": {
            "description": "Wpisz token w formacie: Bearer \u003ctoken_jwt\u003e",
            "type": "apiKey",
            "name": "Authorization",
            "in": "header"
        }
    }
}